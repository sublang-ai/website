// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import type { ImageMetadata } from 'astro';
import { SITE_DESCRIPTION, SITE_GA_CONSENT_KEY, SITE_GA_ID, SITE_TITLE } from '../consts';

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata;
	imageAlt?: string;
	article?: {
		pubDate: Date;
		updatedDate?: Date;
	};
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? canonicalURL.origin;

const { title, description, image, imageAlt, article } = Astro.props;
const ogType = article ? 'article' : 'website';
const pageTitle = title === SITE_TITLE ? title : `${title} | ${SITE_TITLE}`;
const gaId = (import.meta.env.PUBLIC_GA_ID ?? SITE_GA_ID)?.trim();
const gaEnabled = Boolean(gaId);
const gaIdLiteral = JSON.stringify(gaId ?? '');
const consentKeyLiteral = JSON.stringify(SITE_GA_CONSENT_KEY);
const structuredData = {
	'@context': 'https://schema.org',
	'@graph': [
		{
			'@type': 'Organization',
			'@id': `${siteUrl}/#organization`,
			name: SITE_TITLE,
			url: siteUrl,
		},
		{
			'@type': 'WebSite',
			'@id': `${siteUrl}/#website`,
			url: siteUrl,
			name: SITE_TITLE,
			description: SITE_DESCRIPTION,
			publisher: { '@id': `${siteUrl}/#organization` },
		},
		{
			'@type': 'WebPage',
			'@id': `${canonicalURL}#webpage`,
			url: canonicalURL.toString(),
			name: pageTitle,
			description,
			inLanguage: 'en',
			isPartOf: { '@id': `${siteUrl}/#website` },
		},
	],
};
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

{gaEnabled && (
	<>
		<!-- Google Analytics 4 -->
		<script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
		<script
			is:inline
			set:html={`(function(){var gaId=${gaIdLiteral};if(!gaId){return;}window.dataLayer=window.dataLayer||[];function gtag(){window.dataLayer.push(arguments);}window.gtag=window.gtag||gtag;var consent='denied';try{var stored=localStorage.getItem(${consentKeyLiteral});if(stored==='granted'){consent='granted';}}catch(err){}gtag('consent','default',{ad_storage:consent,analytics_storage:consent,ad_user_data:consent,ad_personalization:consent});gtag('js',new Date());gtag('config',gaId);})();`}
		/>
	</>
)}

<!-- Font preloads -->
<link rel="preload" href="/fonts/euclid-circular-a-regular.otf" as="font" type="font/otf" crossorigin />
<link rel="preload" href="/fonts/euclid-circular-a-bold.otf" as="font" type="font/otf" crossorigin />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Hreflang (x-default for future multi-language support) -->
<link rel="alternate" hreflang="x-default" href={canonicalURL} />
<link rel="alternate" hreflang="en" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{pageTitle}</title>
<meta name="title" content={pageTitle} />
<meta name="description" content={description} />
<meta name="robots" content="index,follow" />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={ogType} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
{image && (
	<>
		<meta property="og:image" content={new URL(image.src, Astro.url)} />
		<meta property="og:image:alt" content={imageAlt ?? pageTitle} />
		<meta property="og:image:width" content={String(image.width)} />
		<meta property="og:image:height" content={String(image.height)} />
	</>
)}
<meta property="og:site_name" content={SITE_TITLE} />
<meta property="og:locale" content="en_US" />
{article && (
	<>
		<meta property="article:published_time" content={article.pubDate.toISOString()} />
		{article.updatedDate && (
			<meta property="article:modified_time" content={article.updatedDate.toISOString()} />
		)}
	</>
)}

<!-- Twitter -->
<meta name="twitter:card" content={image ? 'summary_large_image' : 'summary'} />
<meta name="twitter:site" content="@SubLang_xyz" />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
{image && (
	<>
		<meta name="twitter:image" content={new URL(image.src, Astro.url)} />
		<meta name="twitter:image:alt" content={imageAlt ?? pageTitle} />
	</>
)}

<!-- Structured data -->
<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
