---
// SPDX-License-Identifier: AGPL-3.0-or-later
// SPDX-FileCopyrightText: 2026 SubLang International <https://sublang.ai>

import ConsentBanner from './ConsentBanner.astro';

const today = new Date();
---

<footer class="site-footer">
	<div class="footer-inner">
		<div>
			<div class="eyebrow">SubLang International</div>
			<p class="muted">Language tools, reference essays, and engineering notes.</p>
		</div>
		<div class="footer-links">
			<a href="https://github.com/sublang-dev" target="_blank" rel="noopener noreferrer">GitHub</a>
			<a href="https://x.com/sublang_ai" target="_blank" rel="noopener noreferrer">X / Twitter</a>
			<a href="/engineering/">Engineering</a>
		</div>
	</div>
	<div class="footer-meta">&copy; {today.getFullYear()} SubLang International.</div>
</footer>
<ConsentBanner />
<style>
	.site-footer {
		padding: 3.5rem 2rem 4rem;
		border-top: 1px solid var(--line);
		background: rgba(255, 255, 255, 0.65);
	}
	.footer-inner {
		max-width: var(--grid-max);
		margin: 0 auto;
		display: grid;
		gap: 2rem;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		align-items: center;
	}
	.footer-links {
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
		font-family: var(--font-display);
		letter-spacing: 0.14em;
		text-transform: uppercase;
		font-size: 0.8rem;
	}
	.footer-links a {
		border-bottom: none;
		color: var(--ink-muted);
	}
	.footer-links a:hover {
		color: var(--accent);
	}
	.footer-meta {
		max-width: var(--grid-max);
		margin: 2rem auto 0;
		color: var(--ink-muted);
		font-size: 0.85rem;
	}
	@media (max-width: 720px) {
		.site-footer {
			padding: 3rem 1.2rem 3.5rem;
		}
		.footer-links {
			letter-spacing: 0.12em;
		}
	}
</style>
