// SPDX-FileCopyrightText: 2026 SubLang International <https://sublang.ai>

import { SITE_TITLE } from '../consts';
import Wordmark from '../assets/brand/wordmark-color-light-bg.png';
import HeaderLink from './HeaderLink.astro';
---

<header class="site-header">
	<nav>
		<a class="logo" href="/" aria-label={SITE_TITLE}>
			<img
				src={Wordmark.src}
				width={Wordmark.width}
				height={Wordmark.height}
				alt={`${SITE_TITLE} wordmark`}
				loading="eager"
				decoding="async"
			/>
		</a>
		<div class="internal-links" aria-label="Primary navigation">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/engineering/">Engineering</HeaderLink>
		</div>
		<div class="social-links" aria-label="Social links">
			<a href="https://github.com/sublang-dev" target="_blank" rel="noopener noreferrer">
				<span class="sr-only">SubLang on GitHub</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"
					><path
						fill="currentColor"
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path></svg
				>
			</a>
			<a href="https://x.com/sublang_ai" target="_blank" rel="noopener noreferrer">
				<span class="sr-only">SubLang on X</span>
				<svg viewBox="0 0 24 24" aria-hidden="true" width="32" height="32"
					><path
						fill="currentColor"
						d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
					></path></svg
				>
			</a>
		</div>
	</nav>
</header>
<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 10;
		margin: 0;
		padding: 0 2rem;
		background: rgba(247, 244, 239, 0.8);
		backdrop-filter: blur(18px);
		border-bottom: 1px solid var(--line);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 2rem;
		height: 72px;
	}
	.logo {
		display: inline-flex;
		align-items: center;
		border-bottom: none;
	}
	.logo img {
		height: 30px;
		width: auto;
		border-radius: 0;
	}
	.internal-links {
		display: flex;
		align-items: center;
		gap: 1.5rem;
		font-family: var(--font-display);
		font-size: 0.85rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
	}
	.internal-links a {
		border-bottom: none;
		color: var(--ink-muted);
	}
	.internal-links a.active {
		color: var(--ink);
	}
	.social-links {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}
	.social-links a {
		display: inline-flex;
		color: var(--ink-muted);
		border-bottom: none;
		transition: color 0.2s ease, transform 0.2s ease;
	}
	.social-links a:hover {
		color: var(--accent);
		transform: translateY(-1px);
	}
	.social-links svg {
		width: 22px;
		height: 22px;
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
		.site-header {
			padding: 0 1.2rem;
		}
		.logo img {
			height: 24px;
		}
		.internal-links {
			gap: 1rem;
			letter-spacing: 0.16em;
		}
	}
</style>
