import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_AUTHOR, SITE_TITLE } from '../consts';

type Props = CollectionEntry<'ref'>['data'];

const { title, description, pubDate, updatedDate, heroImage, author } = Astro.props;
const postAuthor = author ?? SITE_AUTHOR;
const postImage = heroImage;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? canonicalURL.origin;

const articleSchema = {
	'@context': 'https://schema.org',
	'@type': 'BlogPosting',
	headline: title,
	description,
	datePublished: pubDate.toISOString(),
	dateModified: (updatedDate ?? pubDate).toISOString(),
	author: {
		'@type': 'Person',
		name: postAuthor.name,
	},
	publisher: {
		'@type': 'Organization',
		'@id': `${siteUrl}/#organization`,
		name: SITE_TITLE,
	},
	mainEntityOfPage: {
		'@type': 'WebPage',
		'@id': canonicalURL.toString(),
	},
	...(postImage ? { image: new URL(postImage.src, Astro.url).toString() } : {}),
};
---

<html lang="en">
	<head>
		<BaseHead
			title={title}
			description={description}
			image={postImage}
			article={{ pubDate, updatedDate }}
		/>
		<meta name="author" content={postAuthor.name} />
		<script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
		<style>
			main {
				max-width: var(--grid-max);
				margin: 0 auto;
				padding: 4.5rem 2rem 6rem;
			}
			.article {
				background: var(--surface);
				border: 1px solid var(--line);
				border-radius: var(--radius-lg);
				padding: 2.6rem;
				box-shadow: var(--shadow-soft);
			}
			.hero-image img {
				display: block;
				width: 100%;
				border-radius: var(--radius-md);
			}
			.prose {
				max-width: 720px;
				margin: 2rem auto 0;
				color: var(--ink-soft);
			}
			.title {
				margin-bottom: 1.5rem;
				line-height: 1.1;
			}
			.title h1 {
				margin: 0.8rem 0 0.5rem 0;
			}
			.date {
				display: flex;
				flex-direction: column;
				gap: 0.25rem;
				color: var(--ink-muted);
				font-size: 0.9rem;
				text-transform: uppercase;
				letter-spacing: 0.2em;
				font-family: var(--font-display);
			}
			.last-updated-on {
				font-style: italic;
				letter-spacing: 0.1em;
			}
			@media (max-width: 720px) {
				main {
					padding: 3.5rem 1.2rem 4rem;
				}
				.article {
					padding: 1.8rem;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article class="article">
				{heroImage && (
					<div class="hero-image">
						<Image width={1020} height={510} src={heroImage} alt="" />
					</div>
				)}
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
