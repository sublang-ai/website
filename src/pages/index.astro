import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
<body>
	<Header />
	<main>
		<section class="hero">
			<div>
				<span class="tag">Open Language Lab</span>
				<h1>Language tools for software that reads as well as it runs.</h1>
				<p>
					SubLang explores linguistic models for data management and programming, and the craft of human-readable systems.
					We publish reference essays and engineering notes for teams building expressive software.
				</p>
				<div class="hero-actions">
					<a class="button primary" href="/engineering">Read engineering</a>
					<a class="button" href="https://github.com/sublang-xyz" target="_blank" rel="noopener noreferrer">
						Explore on GitHub
					</a>
					<a class="button" href="https://x.com/sublang_ai" target="_blank" rel="noopener noreferrer">
						Follow on X
					</a>
				</div>
			</div>
			<div class="card">
				<h4>Current focus</h4>
				<ul class="list">
					<li>
						<span class="eyebrow">Readable syntax</span>
						<p>Designing specification layers that communicate intent consistently.</p>
					</li>
					<li>
						<span class="eyebrow">Unified model</span>
						<p>Unifying application logic, data, and knowledge into one computational model.</p>
					</li>
					<li>
						<span class="eyebrow">Data ownership</span>
						<p>Returning data control to users and enabling no-silo access for agents.</p>
					</li>
				</ul>
			</div>
		</section>
		{/*
		<section class="section">
			<div class="split">
				<div>
					<h2>Publishing that favors clarity over noise.</h2>
					<p>
						Our writing and prototypes prioritize rigorous language, elegant structure, and repeatable
						methods. Every note is designed to travel from research to production without losing its meaning.
					</p>
					<p class="muted">
						Start with the engineering log or browse our reference archive for deeper dives.
					</p>
				</div>
				<div class="card">
					<h4>Principles</h4>
					<ul class="list">
						<li>
							<span class="eyebrow">Minimal surface</span>
							<p>Keep interfaces lean so teams stay focused on intent.</p>
						</li>
						<li>
							<span class="eyebrow">Precise words</span>
							<p>Use language that holds up under real world constraints.</p>
						</li>
						<li>
							<span class="eyebrow">Open trail</span>
							<p>Document decisions so collaborators can build with confidence.</p>
						</li>
					</ul>
				</div>
			</div>
		</section>
		*/}
		{/*
		<section class="section">
			<h2>What you will find here</h2>
			<div class="grid">
				<div class="card">
					<h3>Engineering field notes</h3>
					<p>Short essays on building language tools, constraint mapping, and system design.</p>
				</div>
				<div class="card">
					<h3>Reference catalog</h3>
					<p>A growing index of definitions, patterns, and shared terminology for language builders.</p>
				</div>
				<div class="card">
					<h3>Open experiments</h3>
					<p>Prototypes and design sketches that show how future tooling might behave.</p>
				</div>
			</div>
		</section>
		*/}
	</main>
	<Footer />
</body>
</html>
